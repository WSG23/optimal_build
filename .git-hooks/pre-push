#!/bin/bash
# Pre-push hook to enforce code quality before pushing
# Install: ln -sf ../../.git-hooks/pre-push .git/hooks/pre-push

set -e

echo "🔍 Running pre-push quality checks..."
echo ""

# Allow bypass with environment variable
if [ "$SKIP_PRE_PUSH_CHECKS" = "1" ]; then
    echo "⚠️  Skipping pre-push checks (SKIP_PRE_PUSH_CHECKS=1)"
    echo "⚠️  Make sure you know what you're doing!"
    exit 0
fi

# Check if we're on a branch that requires checks
current_branch=$(git rev-parse --abbrev-ref HEAD)
if [[ "$current_branch" == "main" ]] || [[ "$current_branch" == "develop" ]] || [[ "$current_branch" =~ ^(feature|fix|chore)/.* ]]; then
    echo "📋 Checking branch: $current_branch"
else
    echo "ℹ️  Skipping checks for branch: $current_branch"
    exit 0
fi

# Run formatting check
echo "1️⃣  Checking code formatting..."
if ! make format-check > /dev/null 2>&1; then
    echo ""
    echo "❌ Code formatting check failed!"
    echo ""
    echo "Fix it by running:"
    echo "  make format"
    echo ""
    echo "Then try pushing again."
    echo ""
    echo "To bypass this check (not recommended):"
    echo "  SKIP_PRE_PUSH_CHECKS=1 git push"
    echo ""
    exit 1
fi
echo "   ✅ Formatting OK"

# Run linting
echo "2️⃣  Running linters..."
if ! make lint > /dev/null 2>&1; then
    echo ""
    echo "❌ Linting failed!"
    echo ""
    echo "Fix violations and try again."
    echo "Run 'make lint' to see details."
    echo ""
    exit 1
fi
echo "   ✅ Linting OK"

# Run type suppression budgets
echo "3️⃣  Checking type suppression budgets..."
if ! make type-ignore-budget > /dev/null 2>&1; then
    echo ""
    echo "❌ Type suppression budget exceeded!"
    echo ""
    echo "Run 'make type-ignore-budget' to see details."
    echo ""
    exit 1
fi
echo "   ✅ Type suppression budgets OK"

# Run coding rules check
echo "4️⃣  Checking coding rules..."
if ! make check-coding-rules > /dev/null 2>&1; then
    echo ""
    echo "❌ Coding rules violations detected!"
    echo ""
    echo "Run 'make check-coding-rules' to see violations."
    echo "Run 'make format && make verify' to fix most issues."
    echo ""
    exit 1
fi
echo "   ✅ Coding rules OK"

echo ""
echo "✅ All pre-push checks passed!"
echo "   Pushing to remote..."
echo ""

exit 0
