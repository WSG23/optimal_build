# =============================================================================
# Production Environment Template - Security Hardened
# =============================================================================
#
# Copy this file to .env.production and fill in the values.
# NEVER commit .env.production to version control!
#
# Required for production startup (will fail without these):
#   - SECRET_KEY
#   - SQLALCHEMY_DATABASE_URI
#   - BACKEND_ALLOWED_ORIGINS
#   - REDIS_PASSWORD
#   - POSTGRES_PASSWORD
#   - S3_ACCESS_KEY / S3_SECRET_KEY
#
# =============================================================================

# -----------------------------------------------------------------------------
# Core Application
# -----------------------------------------------------------------------------

# Environment identifier (MUST be "production" for production deployments)
ENVIRONMENT=production

# JWT signing key - REQUIRED in production (min 64 chars recommended)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# SECURITY: Must be unique per environment, never reuse across environments
SECRET_KEY=

# Project metadata
PROJECT_NAME="Building Compliance Platform"
PROJECT_VERSION=1.0.0

# Logging level (INFO recommended for production, DEBUG only for troubleshooting)
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# Full database connection URI - REQUIRED in production
# Format: postgresql+asyncpg://user:password@host:port/database
# For Cloud SQL: postgresql+asyncpg://user:password@/database?host=/cloudsql/PROJECT:REGION:INSTANCE
# SECURITY: Use SSL/TLS connection (add ?sslmode=require for most providers)
SQLALCHEMY_DATABASE_URI=

# Individual database components (used if SQLALCHEMY_DATABASE_URI not set)
POSTGRES_SERVER=
POSTGRES_PORT=5432
POSTGRES_USER=
# SECURITY: Must be strong (min 32 chars, mixed case, numbers, symbols)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=
POSTGRES_DB=building_compliance

# PostGIS support (set to 1 for spatial queries)
BUILDABLE_USE_POSTGIS=1

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------

# Allowed origins for CORS - REQUIRED in production
# Comma-separated list of allowed frontend URLs
# SECURITY: Only list your actual frontend domains, never use wildcards (*)
# Example: https://optimal-build.com,https://www.optimal-build.com
BACKEND_ALLOWED_ORIGINS=

# Allowed hosts for Host header validation
# SECURITY: Should match your domain names exactly
ALLOWED_HOSTS=

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------

# Redis connection URL - MUST include password in production
# Format: redis://:password@host:port
# SECURITY: Always use password authentication in production
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# SECURITY: Redis password - REQUIRED in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=

# Celery broker and result backend (include password)
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/1

# RQ (Redis Queue) URL (include password)
RQ_REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/2

# Rate limiting storage (include password)
RATE_LIMIT_STORAGE_URI=redis://:${REDIS_PASSWORD}@redis:6379/3

# API rate limit (requests per minute) - adjust based on expected traffic
API_RATE_LIMIT=60/minute

# -----------------------------------------------------------------------------
# Object Storage (S3-Compatible)
# -----------------------------------------------------------------------------

# MinIO/S3 endpoint
# For Cloud Storage: https://storage.googleapis.com
# For AWS S3: https://s3.amazonaws.com
S3_ENDPOINT=

# SECURITY: Access credentials - REQUIRED in production
# Use dedicated service account credentials, not root/admin keys
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Bucket names
IMPORTS_BUCKET_NAME=cad-imports
EXPORTS_BUCKET_NAME=cad-exports
DOCUMENTS_BUCKET_NAME=documents

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Default admin user (created on first startup if not exists)
FIRST_SUPERUSER=admin@your-domain.com
# SECURITY: Change immediately after first login
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
FIRST_SUPERUSER_PASSWORD=

# Token encryption for listing integrations
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
LISTING_TOKEN_SECRET=

# Default role for new users (viewer = read-only, safest default)
DEFAULT_ROLE=viewer

# -----------------------------------------------------------------------------
# External API Keys
# -----------------------------------------------------------------------------

# Hong Kong data sources
HK_DATA_GOV_API_KEY=
HK_GEOSPATIAL_TOKEN=

# New Zealand LINZ
NZ_LINZ_API_KEY=

# US city data (SODA)
SEATTLE_SODA_APP_TOKEN=
TORONTO_SODA_APP_TOKEN=

# OpenAI (for AI features)
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Performance Tuning
# -----------------------------------------------------------------------------

# Gunicorn workers (typically 2-4 x CPU cores)
WEB_CONCURRENCY=4

# Slow query threshold for logging (seconds)
SLOW_QUERY_THRESHOLD_SECONDS=0.5

# Preview asset retention
PREVIEW_MAX_VERSIONS=3
PREVIEW_GEOMETRY_DETAIL_LEVEL=medium

# Building calculation defaults
BUILDABLE_TYP_FLOOR_TO_FLOOR_M=4.0
BUILDABLE_EFFICIENCY_RATIO=0.82

# -----------------------------------------------------------------------------
# Feature Flags - Security Critical
# -----------------------------------------------------------------------------

# SECURITY: MUST be 0 in production - allows viewers to modify data if enabled
ALLOW_VIEWER_MUTATIONS=0

# Offline mode (disable external API calls)
OFFLINE_MODE=0

# -----------------------------------------------------------------------------
# Docker/Container Settings
# -----------------------------------------------------------------------------

# Container port
PORT=8080

# Image tag for deployments (use specific version tags, never 'latest' in production)
IMAGE_TAG=

# Exposed ports (for docker-compose)
# SECURITY: Only frontend port should be exposed externally in production
FRONTEND_PORT=3000

# These are INTERNAL ports - not exposed to host in hardened configuration
# BACKEND_PORT=8080  # Internal only
# POSTGRES_PORT=5432  # Internal only
# REDIS_PORT=6379    # Internal only
# MINIO_API_PORT=9000  # Internal only
# MINIO_CONSOLE_PORT=9001  # Internal only

# Frontend API URL (for build-time injection)
VITE_API_BASE_URL=/api

# =============================================================================
# Security Checklist Before Deployment
# =============================================================================
#
# [ ] All SECRET_KEY values are unique and randomly generated
# [ ] Database password is strong (32+ chars)
# [ ] Redis password is strong (32+ chars)
# [ ] S3/MinIO credentials are from dedicated service account
# [ ] BACKEND_ALLOWED_ORIGINS contains only your frontend URLs
# [ ] ALLOW_VIEWER_MUTATIONS is set to 0
# [ ] LOG_LEVEL is INFO (not DEBUG)
# [ ] All default passwords have been changed
# [ ] SSL/TLS is configured for database connections
# [ ] This file is NOT committed to version control
#
# =============================================================================
