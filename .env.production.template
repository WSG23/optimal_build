# =============================================================================
# Production Environment Template
# =============================================================================
#
# Copy this file to .env.production and fill in the values.
# NEVER commit .env.production to version control!
#
# Required for production startup:
#   - SECRET_KEY
#   - SQLALCHEMY_DATABASE_URI
#   - BACKEND_ALLOWED_ORIGINS
#
# =============================================================================

# -----------------------------------------------------------------------------
# Core Application
# -----------------------------------------------------------------------------

# Environment identifier (MUST be "production" for production deployments)
ENVIRONMENT=production

# JWT signing key - REQUIRED in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Project metadata
PROJECT_NAME="Building Compliance Platform"
PROJECT_VERSION=1.0.0

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# Full database connection URI - REQUIRED in production
# Format: postgresql+asyncpg://user:password@host:port/database
# For Cloud SQL: postgresql+asyncpg://user:password@/database?host=/cloudsql/PROJECT:REGION:INSTANCE
SQLALCHEMY_DATABASE_URI=

# Individual database components (optional if SQLALCHEMY_DATABASE_URI is set)
POSTGRES_SERVER=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=building_compliance

# PostGIS support (set to 1 for spatial queries)
BUILDABLE_USE_POSTGIS=1

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------

# Allowed origins for CORS - REQUIRED in production
# Comma-separated list of allowed frontend URLs
# Example: https://optimal-build.com,https://www.optimal-build.com
BACKEND_ALLOWED_ORIGINS=

# Allowed hosts for Host header validation
ALLOWED_HOSTS=

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------

# Redis connection URL
# For Memorystore: redis://10.x.x.x:6379
REDIS_URL=redis://localhost:6379

# Celery broker and result backend
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# RQ (Redis Queue) URL
RQ_REDIS_URL=redis://localhost:6379/2

# Rate limiting storage
RATE_LIMIT_STORAGE_URI=redis://localhost:6379/3

# API rate limit (requests per minute)
API_RATE_LIMIT=60/minute

# -----------------------------------------------------------------------------
# Object Storage (S3-Compatible)
# -----------------------------------------------------------------------------

# MinIO/S3 endpoint
# For Cloud Storage: https://storage.googleapis.com
S3_ENDPOINT=

# Access credentials
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Bucket names
IMPORTS_BUCKET_NAME=cad-imports
EXPORTS_BUCKET_NAME=cad-exports
DOCUMENTS_BUCKET_NAME=documents

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Default admin user (created on first startup if not exists)
FIRST_SUPERUSER=admin@optimal-build.com
FIRST_SUPERUSER_PASSWORD=

# Token encryption for listing integrations
LISTING_TOKEN_SECRET=

# Default role for new users
DEFAULT_ROLE=viewer

# -----------------------------------------------------------------------------
# External API Keys
# -----------------------------------------------------------------------------

# Hong Kong data sources
HK_DATA_GOV_API_KEY=
HK_GEOSPATIAL_TOKEN=

# New Zealand LINZ
NZ_LINZ_API_KEY=

# US city data (SODA)
SEATTLE_SODA_APP_TOKEN=
TORONTO_SODA_APP_TOKEN=

# OpenAI (for AI features)
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Performance Tuning
# -----------------------------------------------------------------------------

# Gunicorn workers (typically 2-4 x CPU cores)
WEB_CONCURRENCY=4

# Slow query threshold for logging (seconds)
SLOW_QUERY_THRESHOLD_SECONDS=0.5

# Preview asset retention
PREVIEW_MAX_VERSIONS=3
PREVIEW_GEOMETRY_DETAIL_LEVEL=medium

# Building calculation defaults
BUILDABLE_TYP_FLOOR_TO_FLOOR_M=4.0
BUILDABLE_EFFICIENCY_RATIO=0.82

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Allow viewer role to make mutations (DANGEROUS - set to 0 in production)
ALLOW_VIEWER_MUTATIONS=0

# Offline mode (disable external API calls)
OFFLINE_MODE=0

# -----------------------------------------------------------------------------
# Docker/Container Settings
# -----------------------------------------------------------------------------

# Container port
PORT=8080

# Image tag for deployments
IMAGE_TAG=latest

# Exposed ports (for docker-compose)
BACKEND_PORT=8080
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Frontend API URL (for build-time injection)
VITE_API_BASE_URL=/api
